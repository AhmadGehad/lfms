  "query": "\nSELECT \n  ac.name AS category,\n  fi.name AS feedItem,\n  fi.unit,\n  rp.qtyPerHeadPerDay,\n  COUNT(*) AS duplicateCount,\n  MIN(rp.id) AS keepId,\n  MIN(rp.effectiveDate) AS effectiveDate\nFROM ration_plans rp\nLEFT JOIN feed_items fi ON fi.id = rp.feedItemId\nLEFT JOIN animal_categories ac ON ac.id = rp.categoryId\nWHERE rp.deletedAt IS NULL AND rp.isActive = 1\nGROUP BY ac.name, fi.name, fi.unit, rp.qtyPerHeadPerDay\nORDER BY ac.name, fi.name;\n",
