{
  "query": "\nSELECT \n  fi.name as feed_item,\n  rp.qtyPerHeadPerDay,\n  fph.pricePerUnit,\n  rp.qtyPerHeadPerDay * fph.pricePerUnit as cost_per_head_per_day,\n  (SELECT COUNT(*) FROM animals a WHERE a.categoryId = rp.categoryId AND a.isActive = 1 AND a.deletedAt IS NULL) as active_heads,\n  rp.qtyPerHeadPerDay * fph.pricePerUnit * (SELECT COUNT(*) FROM animals a WHERE a.categoryId = rp.categoryId AND a.isActive = 1 AND a.deletedAt IS NULL) as daily_feed_cost\nFROM ration_plans rp\nJOIN feed_items fi ON rp.feedItemId = fi.id\nJOIN feed_item_price_history fph ON fph.feedItemId = fi.id\nWHERE rp.deletedAt IS NULL AND rp.isActive = 1\n  AND fph.effectiveDate = (SELECT MAX(fph2.effectiveDate) FROM feed_item_price_history fph2 WHERE fph2.feedItemId = fi.id)\nORDER BY daily_feed_cost DESC\nLIMIT 15;\n",
  "command": "mysql --batch --raw --column-names --default-character-set=utf8mb4 --host gateway06.us-east-1.prod.aws.tidbcloud.com --port 4000 --user 2Miqjapjuirru1Z.b9867fc13f8f --database boyWMBM5odtbpptCLrtK7n --execute \nSELECT \n  fi.name as feed_item,\n  rp.qtyPerHeadPerDay,\n  fph.pricePerUnit,\n  rp.qtyPerHeadPerDay * fph.pricePerUnit as cost_per_head_per_day,\n  (SELECT COUNT(*) FROM animals a WHERE a.categoryId = rp.categoryId AND a.isActive = 1 AND a.deletedAt IS NULL) as active_heads,\n  rp.qtyPerHeadPerDay * fph.pricePerUnit * (SELECT COUNT(*) FROM animals a WHERE a.categoryId = rp.categoryId AND a.isActive = 1 AND a.deletedAt IS NULL) as daily_feed_cost\nFROM ration_plans rp\nJOIN feed_items fi ON rp.feedItemId = fi.id\nJOIN feed_item_price_history fph ON fph.feedItemId = fi.id\nWHERE rp.deletedAt IS NULL AND rp.isActive = 1\n  AND fph.effectiveDate = (SELECT MAX(fph2.effectiveDate) FROM feed_item_price_history fph2 WHERE fph2.feedItemId = fi.id)\nORDER BY daily_feed_cost DESC\nLIMIT 15;\n",
