{
  "query": "\nSELECT fi.name as feed_item, fi.unit,\n       rp.qtyPerHeadPerDay, rp.effectiveDate,\n       ac.name as category,\n       (SELECT COUNT(*) FROM animals a WHERE a.categoryId = rp.categoryId AND a.isActive = 1 AND a.deletedAt IS NULL) as active_animals,\n       rp.qtyPerHeadPerDay * (SELECT COUNT(*) FROM animals a WHERE a.categoryId = rp.categoryId AND a.isActive = 1 AND a.deletedAt IS NULL) as daily_total_kg\nFROM ration_plans rp\nJOIN feed_items fi ON rp.feedItemId = fi.id\nJOIN animal_categories ac ON rp.categoryId = ac.id\nWHERE rp.deletedAt IS NULL AND rp.isActive = 1\nORDER BY fi.name;\n",
