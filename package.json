{
  "name": "lfms",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:admin": "vite --config vite.admin.config.ts",
    "dev:worker": "NODE_ENV=development tsx watch server/workers/index.ts",
    "build": "pnpm run build:tenant && pnpm run build:admin && pnpm run build:cloudflare-assets && pnpm run build:server && pnpm run build:worker",
    "build:tenant": "vite build",
    "build:admin": "vite build --config vite.admin.config.ts",
    "build:cloudflare-assets": "node scripts/prepare-cloudflare-assets.mjs",
    "build:server": "esbuild server/_core/index.ts server/_core/vite.ts --platform=node --packages=external --bundle --format=esm --splitting --outdir=dist",
    "build:worker": "esbuild server/workers/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/worker.js",
    "start": "NODE_ENV=production node dist/index.js",
    "start:worker": "NODE_ENV=production node dist/worker.js",
    "check": "tsc --noEmit && tsc -p cloudflare/tsconfig.json",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:cloudflare-secrets": "node scripts/check-cloudflare-secrets.mjs",
    "cloudflare:dev": "wrangler dev",
    "cloudflare:deploy": "node scripts/deploy-cloudflare.mjs production",
    "cloudflare:deploy:staging": "node scripts/deploy-cloudflare.mjs staging",
    "cloudflare:rollback": "wrangler rollback --env \"\"",
    "cloudflare:rollback:staging": "wrangler rollback --env staging",
    "cloudflare:status": "wrangler containers list --env \"\"",
    "cloudflare:status:staging": "wrangler containers list --env staging",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:regression": "node tests/regression.mjs",
    "db:push": "node scripts/refuse-legacy-schema-write.mjs",
    "db:rehearse-tenancy": "node scripts/rehearse-tenancy-migration.mjs",
    "db:migrate-tenancy": "MIGRATION_MODE=production node scripts/rehearse-tenancy-migration.mjs",
    "admin:bootstrap": "tsx scripts/bootstrap-platform-admin.ts",
    "admin:bootstrap:password": "tsx scripts/bootstrap-platform-admin-password.ts"
  },
