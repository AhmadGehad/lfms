# Local development only. Never place production credentials here.
NODE_ENV=development
PORT=3000
SHUTDOWN_TIMEOUT_MS=30000
DATABASE_URL=mysql://127.0.0.1:3306/lfms
DB_POOL_CONNECTION_LIMIT=5
DB_POOL_QUEUE_LIMIT=50
JWT_SECRET=replace-with-at-least-32-random-bytes
SESSION_PEPPER=replace-with-at-least-32-random-bytes
OAUTH_STATE_SECRET=replace-with-at-least-32-random-bytes

VITE_APP_ID=local-test-app
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
OAUTH_ALLOWED_HOSTS=api.manus.im,manus.im

BASE_DOMAIN=localhost
VITE_ENABLE_LOCAL_DEV_AUTH=0
TRUST_PROXY_CIDRS=
ADMIN_ORIGIN=http://admin.localhost:3010
ALLOWED_TENANT_ORIGINS=http://localhost:3000
CSP_SCRIPT_ORIGINS=
CSP_CONNECT_ORIGINS=
CSP_IMAGE_ORIGINS=

# Reserved for a future distributed cache. The current application does not use it.
REDIS_URL=
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=lfms-local
OBJECT_STORAGE_ACCESS_KEY_ID=local-development-only
OBJECT_STORAGE_SECRET_ACCESS_KEY=local-development-only
OBJECT_STORAGE_KMS_KEY_ID=

# Optional: leave blank to skip sending real password-reset emails (the reset
# link is logged instead). Configure all of these to send via SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=0

# Optional: leave all four blank to use the default Manus Admin login.
ADMIN_OIDC_ISSUER=
ADMIN_OIDC_CLIENT_ID=
ADMIN_OIDC_CLIENT_SECRET=
ADMIN_OIDC_REDIRECT_URI=
ADMIN_OIDC_MFA_ACR_VALUES=
ADMIN_BOOTSTRAP_OIDC_SUBJECT=
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_NAME=
ADMIN_BOOTSTRAP_ROLE=platform_admin

LOG_LEVEL=debug
# Reserved. Distributed OpenTelemetry export is not implemented yet.
OTEL_EXPORTER_OTLP_ENDPOINT=
METRICS_BEARER_TOKEN=replace-with-at-least-32-random-bytes
DEPLOY_VERSION=local
JOB_LEASE_MS=60000
JOB_IDLE_MS=1000
WORKER_SHUTDOWN_TIMEOUT_MS=90000
WORKER_ID=

OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.ai
VITE_APP_TITLE=Livestock Farm Management System
VITE_SUPPORT_EMAIL=support@example.test
VITE_DEFAULT_DESIGN=old
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
